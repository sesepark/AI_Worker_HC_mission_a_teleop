FROM robotis/ros:jazzy-ros-base-torch2.7.0-cuda12.8.0-v3 AS physical-ai-tools

ARG S6_OVERLAY_VERSION=3.2.1.0

# Install s6-overlay
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz /tmp
RUN tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz /tmp
RUN tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive

# Install realsense and physical_ai_tools dependencies
RUN apt-get update && apt-get install -y \
    xz-utils \
    ffmpeg \
    vim \
    nano \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

ENV COLCON_WS=/root/ros2_ws
WORKDIR ${COLCON_WS}

RUN mkdir -p ${COLCON_WS}/src && \
    cd ${COLCON_WS}/src && \
    git clone -b jazzy https://github.com/ROBOTIS-GIT/physical_ai_tools.git --recursive

RUN cd ${COLCON_WS} && \
    apt-get update && \
    rosdep update && \
    rosdep install -i --from-path src --rosdistro $ROS_DISTRO -y && \
    rm -rf /var/lib/apt/lists/*


RUN cd ${COLCON_WS}/src/physical_ai_tools/lerobot && \
    sed -i '/"torch[^\"]*",/d' pyproject.toml && \
    sed -i '/"torchvision[^\"]*",/d' pyproject.toml && \
    pip install --ignore-installed -e .

RUN cd ${COLCON_WS}/src/physical_ai_tools/lerobot && \
    pip install -e ".[smolvla]"

RUN pip install --no-cache-dir setuptools==68.1.2
RUN pip install --no-cache-dir 'numpy<2'

RUN echo 'export PYTHONPATH=${COLCON_WS}/src/physical_ai_tools/lerobot/src:$PYTHONPATH' >> /root/.bashrc && \
    export PYTHONPATH=${COLCON_WS}/src/physical_ai_tools/lerobot/src:$PYTHONPATH

RUN bash -c "source /opt/ros/${ROS_DISTRO}/setup.bash && \
    cd ${COLCON_WS} && \
    colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Release"

RUN echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> ~/.bashrc  && \
    echo "source ${COLCON_WS}/install/setup.bash" >> ~/.bashrc  && \
    echo "alias cb='colcon build --symlink-install --cmake-args -DCMAKE_BUILD_TYPE=Release'" >> ~/.bashrc && \
    echo "alias ai_server='ros2 launch physical_ai_server physical_ai_server_bringup.launch.py'" >> ~/.bashrc && \
    echo "export ROS_DOMAIN_ID=30" >> ~/.bashrc

# Create directory for agent Unix Domain Socket
RUN mkdir -p /var/run/agent && \
    chmod 777 /var/run/agent

RUN git clone -b main https://github.com/ROBOTIS-GIT/cyclo_manager.git /opt/cyclo_manager

ENV PYTHONPATH=/opt/cyclo_manager:${PYTHONPATH}

RUN pip install --no-cache-dir -r /opt/cyclo_manager/requirements.txt

# s6-rc services: s6-agent, physical_ai_server (longrun + log pipeline)
COPY docker/s6-agent /etc/s6-overlay/s6-rc.d/s6-agent
COPY docker/s6-services /etc/s6-overlay/s6-rc.d/
RUN rm -rf /etc/s6-overlay/s6-rc.d/common
RUN chmod +x /etc/s6-overlay/s6-rc.d/s6-agent/run /etc/s6-overlay/s6-rc.d/s6-agent/finish \
    /etc/s6-overlay/s6-rc.d/physical_ai_server/run /etc/s6-overlay/s6-rc.d/physical_ai_server/finish \
    /etc/s6-overlay/s6-rc.d/physical_ai_server-log/run

# Copy reusable ROS2 service scripts to a location outside s6-rc.d
# This prevents s6-rc-compile from treating them as services
RUN mkdir -p /usr/local/lib/s6-services
COPY docker/s6-services/common/ros2_service_run.sh /usr/local/lib/s6-services/ros2_service_run.sh
COPY docker/s6-services/common/ros2_service_finish.sh /usr/local/lib/s6-services/ros2_service_finish.sh
RUN chmod +x /usr/local/lib/s6-services/ros2_service_run.sh && \
    chmod +x /usr/local/lib/s6-services/ros2_service_finish.sh

# Create log directory and set permissions
RUN mkdir -p /var/log/physical_ai_server && \
    chown nobody:nogroup /var/log/physical_ai_server && \
    chmod 02755 /var/log/physical_ai_server

RUN mkdir -p /etc/s6-overlay/s6-rc.d/user/contents.d && \
    touch /etc/s6-overlay/s6-rc.d/user/contents.d/s6-agent

# Set s6-overlay as entrypoint
ENTRYPOINT ["/init"]
